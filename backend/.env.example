# ================================================================
# ProYou — Backend Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit your actual .env file.
# ================================================================

PORT=3001

# JWT secret — use a long, random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Google OAuth Client ID (from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# MongoDB Atlas connection string
# https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=

# Groq AI (free tier, fast inference)
# https://console.groq.com/keys
GROQ_API_KEY=

# GitHub Personal Access Token (boosts rate limit to 5000 req/hr)
# https://github.com/settings/tokens → Generate new token (classic) → public_repo scope
GITHUB_TOKEN=

# NewsAPI (100 req/day on free tier)
# https://newsapi.org/register
NEWS_API_KEY=

# Gmail SMTP via nodemailer (500 emails/day, free, no domain needed)
# Step 1: Enable 2FA → myaccount.google.com/security
# Step 2: Generate App Password → myaccount.google.com/apppasswords
#         App: Mail | Device: Other (name it ProYou) → copy the 16-char code
GMAIL_USER=you@gmail.com
GMAIL_PASS=
EMAIL_FROM=ProYou <you@gmail.com>

# Frontend origin (used for CORS and password-reset links)
FRONTEND_URL=http://localhost:5173

# Admin email for cron failure alerts (optional but recommended in production)
ADMIN_EMAIL=
